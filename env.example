# Environment Configuration
ENVIRONMENT=development
DEBUG=true

# Security Settings
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database Configuration - MongoDB Atlas
# Replace with your actual MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
DB_NAME=signglove

# Example MongoDB Atlas connection string format:
# MONGO_URI=mongodb+srv://yourusername:yourpassword@cluster0.abc123.mongodb.net/signglove?retryWrites=true&w=majority

# CORS Settings
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:8080"]

# Backend base URL used by backend internal calls and collectors
BACKEND_BASE_URL=http://localhost:8000

# Auth / JWT
SECRET_KEY=change-me-in-prod
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
COOKIE_SECURE=false

# Optional: auto-seed default users (admin/editor/guest) on startup and auth calls.
# Keep true for local/dev onboarding; set false in production.
AUTO_SEED_DEFAULT_USERS=true
DEFAULT_ADMIN_EMAIL=admin@signglove.com
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_EDITOR_EMAIL=editor@signglove.com
DEFAULT_EDITOR_PASSWORD=editor123
DEFAULT_GUEST_EMAIL=user@signglove.com
DEFAULT_GUEST_PASSWORD=user123

# TTS Configuration
TTS_ENABLED=true
TTS_PROVIDER=gtts
TTS_VOICE=ur-IN-SalmanNeural
TTS_RATE=150
TTS_VOLUME=2.0
TTS_CACHE_ENABLED=true
TTS_CACHE_DIR=tts_cache
TTS_FILTER_IDLE_GESTURES=true

# Performance and Monitoring
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
MAX_REQUEST_SIZE=10485760
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_EXCLUDE_PREFIXES=["/predict/integrated","/early-fusion","/gesture"]

# File Upload Settings
UPLOAD_DIR=uploads
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=[".csv",".json",".txt"]

# Runtime flags
RUNTIME_PREFLIGHT_ON_STARTUP=true
INTEGRATED_MIN_FRAMES=5

# Runtime split (phase 1 scaffold)
# Keep false until backend dispatch is wired to runtime services.
USE_RUNTIME_SERVICES=false
ML_TENSORFLOW_URL=http://ml-tensorflow:8091
ML_PYTORCH_URL=http://ml-pytorch:8092
USE_WORKER_LIBRARY=false
WORKER_LIBRARY_URL=http://worker-library:8093
USE_EARLY_FUSION_WORKER=false
EARLY_FUSION_WORKER_URL=http://worker-early-fusion:8095
EARLY_FUSION_SEQUENCE_LENGTH=30
EARLY_FUSION_FEATURE_DIM=74
EARLY_FUSION_LABELS=rest,hello,thank_you,yes,no,bye
EARLY_FUSION_MODEL_PATH=/app/AI/models/sign_lstm_model.keras

# Worker library service (registry/model-library maintenance)
MODEL_LIBRARY_DIR=/app/AI/model_library
WORKER_RECONCILE_INTERVAL_SEC=300
WORKER_RECONCILE_PRUNE_MISSING=false
WORKER_RECONCILE_APPLY_ON_STARTUP=true

# Legacy local fallback (optional, for non-runtime-split dev only)
LEGACY_TFLITE_MODEL_PATH=/app/AI/gesture_model.tflite
LEGACY_TRAINING_METRICS_PATH=/app/AI/training_metrics.json

# Monitoring alert thresholds
MONITORING_WINDOW_SECONDS=300
MONITORING_CACHE_TTL_SECONDS=15
MONITORING_RUNTIME_HEALTH_TIMEOUT_SECONDS=1.5
MONITORING_WARN_ERROR_RATE_5M_PCT=2.0
MONITORING_CRIT_ERROR_RATE_5M_PCT=5.0
MONITORING_WARN_LATENCY_P95_MS=500
MONITORING_CRIT_LATENCY_P95_MS=1000
MONITORING_WARN_DROP_RATE=0.02
MONITORING_WARN_MISSING_RATIO=0.01
MONITORING_WARN_DRIFT_SCORE=0.75

# Production Settings (uncomment for production)
# ENVIRONMENT=production
# DEBUG=false
# JWT_SECRET_KEY=your-production-secret-key-here
# CORS_ORIGINS=https://yourdomain.com,https://api.yourdomain.com 
